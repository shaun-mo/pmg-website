{
  "name": "pmg-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:website": "bun --filter pmg-website dev",
    "dev:ats": "bun --filter pmg-ats dev",
    "build:website": "bun --filter pmg-website build",
    "build:ats": "bun --filter pmg-ats build",
    "lint": "bun --filter '*' lint",
    "typecheck": "bun --filter '*' typecheck"
  }
}
