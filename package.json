{
  "name": "pmg-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:website": "turbo dev --filter=pmg-website",
    "dev:ats": "turbo dev --filter=pmg-ats",
    "build": "turbo build",
    "build:website": "turbo build --filter=pmg-website",
    "build:ats": "turbo build --filter=pmg-ats",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.9.15",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
